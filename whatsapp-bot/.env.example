# ─── Twilio ───
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cloudinary ───
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Sheets ───
# ID del Google Sheet (lo sacas de la URL: https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit)
GOOGLE_SHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Credenciales del service account (JSON en una sola línea)
# Copia todo el contenido del archivo .json descargado y pégalo aquí en una línea
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Stripe ───
STRIPE_SECRET_KEY=tu_clave_secreta_de_stripe_aqui
STRIPE_WEBHOOK_SECRET=tu_webhook_secret_de_stripe_aqui

# ─── Notificación de pedidos ───
# Número de WhatsApp del dueño (con código de país, ej: +34609659015)
OWNER_WHATSAPP_NUMBER=+34609659015
# Número de Twilio WhatsApp (sandbox: +14155238886, o tu número de producción)
TWILIO_WHATSAPP_FROM=+14155238886
# URL del frontend (sin barra final)
FRONTEND_URL=https://ambitos.es

# ─── Servidor ───
PORT=3000
